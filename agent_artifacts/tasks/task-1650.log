  game.js:2364:    drawSingleTile(x, y, type) {
  game.js:2365:        let matrix = null;
  game.js:2366:        if (type === TILES.GROUND) matrix = SPRITES.TILES.GROUND;
  game.js:2367:        else if (type === TILES.PLATFORM) matrix = SPRITES.TILES.PLATFORM;
  game.js:2368:        else if (type === TILES.BREAKABLE) matrix = SPRITES.TILES.BREAKABLE;
  game.js:2369:        else if (type === TILES.REWARD) {
  game.js:2370:            // Draw the ground-brown base tile first
  game.js:2371:            drawPixelMatrix(this.ctx, x, y, SPRITES.TILES.REWARD, false, 4.5);
  game.js:2372:            // Pulsing orange-red glow overlay using 'lighter' composite (sin wave 0..1)
  game.js:2373:            const pulse = (Math.sin(this.frameCounter * 0.12) + 1) / 2; // 0..1 oscillation
  game.js:2374:            this.ctx.save();
