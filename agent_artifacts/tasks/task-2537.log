            for (let c = startCol; c <= endCol; c++) {
                const tile = this.getTile(c, r);
                if (tile !== TILES.EMPTY) {
                    this.drawSingleTile(c * TILE_SIZE, r * TILE_SIZE, tile);
                }
            }
        }
    }

