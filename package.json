{
  "name": "hexlys-inferno",
  "version": "1.0.0",
  "description": "Retro 2D Platformer Desktop Game",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win"
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "jimp": "^1.6.1",
    "puppeteer": "^25.1.0"
  },
  "build": {
